FROM ghcr.io/ublue-os/bazzite:stable

# ── Microsoft Surface support ─────────────────────────────────────────────────
# NOTE: We intentionally do NOT swap in the linux-surface kernel.
#   1. linux-surface has no Fedora 44 repo yet (Bazzite stable is now F44),
#      so its repo 404s.
#   2. Its packages are named kernel-surface*, not kernel/kernel-core, so a
#      drop-in override replace was never going to work.
#   3. Bazzite's stock kernel (kernel-bazzite) already carries Surface hardware
#      patches, and `bazzite-hardware-setup` auto-detects Surface devices and
#      loads the correct modules (surface_aggregator, surface_hid, surface_kbd,
#      pinctrl_*, intel_lpss, …) at first boot. This is the supported path.
# If a Surface-specific fix is ever needed that isn't in kernel-bazzite, revisit
# once pkg.surfacelinux.com/fedora/f44/ exists.
#
# The Surface Pro 2 (2013, Haswell) predates IPTS/IPU, so ALL its hardware uses
# in-kernel drivers already present in kernel-bazzite:
#   • Cameras  → uvcvideo (they're plain USB webcams, 045e:0794 / 045e:0795)
#   • Touch    → hid-multitouch (Atmel digitizer 03eb:8209)
#   • Pen      → wacom (HID)
#   • WiFi/BT  → mwifiex_usb + btusb (Marvell 88W8797, 1286:2044)
#   • Audio    → snd_hda_intel (Intel Lynx Point-LP)
#   • Backlight→ i915 native
# The only real-world quirks need config, not drivers:

# ── ISO build prep ────────────────────────────────────────────────────────────
# bootc-image-builder depsolves every enabled repo in the image to assemble the
# installer. Bazzite's third-party Terra repos point at a GPG key file that
# isn't shipped (/etc/pki/rpm-gpg/RPM-GPG-KEY-terra44-mesa), which breaks that
# depsolve. Disable them — the OS ships as this bootc image and Bazzite already
# bakes in the Terra packages (mesa, etc.); these repos are only for optional
# local layering.
RUN sed -i 's/^enabled[[:space:]]*=[[:space:]]*1/enabled=0/' \
        /etc/yum.repos.d/terra*.repo 2>/dev/null || true

# ── Surface Pro 2 hardware quirk fixes ────────────────────────────────────────
# WiFi: stop USB autosuspend from killing the Marvell adapter (USB variant)
COPY config/surface/81-mwifiex-no-autosuspend.rules /usr/lib/udev/rules.d/81-mwifiex-no-autosuspend.rules
# WiFi: deactivate auto deep-sleep (firmware-hang fix, valid for USB + PCIe)
COPY config/surface/mwifiex.conf                    /usr/lib/modprobe.d/mwifiex.conf
# WiFi: disable power save globally (bus-agnostic, the reliable fix)
COPY config/surface/wifi-powersave.conf             /usr/lib/NetworkManager/conf.d/wifi-powersave.conf
# Suspend: ignore the buggy SP1/SP2 lid sensor (prevents infinite suspend loop)
COPY config/surface/10-surface-lid.conf             /usr/lib/systemd/logind.conf.d/10-surface-lid.conf
# Kernel arg companion for the lid fix, applied by bootc at install time
COPY config/surface/01-surface-kargs.toml           /usr/lib/bootc/kargs.d/01-surface-kargs.toml

# ── SlozOS branding ───────────────────────────────────────────────────────────
COPY assets/wallpapers/          /usr/share/wallpapers/SlozOS/
COPY assets/logo/slozos-logo.png /usr/share/pixmaps/slozos-logo.png
COPY config/sddm/slozos/         /usr/share/sddm/themes/slozos/
COPY config/kde/SlozOS.colors    /usr/share/color-schemes/SlozOS.colors

RUN echo "slozos" > /etc/hostname && \
    sed -i \
        -e 's/^NAME=.*/NAME="SlozOS"/' \
        -e 's/^PRETTY_NAME=.*/PRETTY_NAME="SlozOS 1.0 (Bazzite)"/' \
        /usr/lib/os-release 2>/dev/null || true

LABEL org.opencontainers.image.title="SlozOS"
LABEL org.opencontainers.image.description="SlozOS — Bazzite gaming OS for Microsoft Surface"
